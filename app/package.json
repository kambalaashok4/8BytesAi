{
  "name": "devops-assignment-app",
  "version": "1.0.0",
  "description": "Simple REST API demonstrating production DevOps practices",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --forceExit --coverage",
    "test:ci": "jest --forceExit --coverage --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint 'src/**/*.js' 'tests/**/*.js'",
    "lint:fix": "eslint 'src/**/*.js' 'tests/**/*.js' --fix"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "prom-client": "^15.1.2"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70
      }
    }
  }
}
